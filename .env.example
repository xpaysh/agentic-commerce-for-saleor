# Per-merchant identity
XPAY_MERCHANT_SLUG=acme-outdoors
SITE_URL=https://store.acme.example/
SITE_NAME=Acme Outdoors
SITE_DESCRIPTION=Climbing gear and trail food

# Shared HS256 secret for cart-deeplink JWTs.
# Get this from your xpay merchant account: app.xpay.sh/onboard/saleor
XPAY_API_KEY=xpay_live_REPLACE_ME

# Saleor GraphQL API
# Auth: Bearer App token. Create in Saleor Dashboard → Configuration → Apps →
# Local Apps → Create App. Grant the permissions listed in README.md.
SALEOR_API_URL=https://store.acme.example/graphql/
SALEOR_APP_TOKEN=REPLACE_WITH_APP_TOKEN
# Channel slug (every Saleor query needs a channel; usually 'default-channel')
SALEOR_CHANNEL=default-channel

# Optional
HOST=0.0.0.0
PORT=8787
CHECKOUT_PATH=/checkout
EMIT_OAUTH_PROTECTED_RESOURCE=0
EMIT_AGENT_CARD=0
